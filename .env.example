# Threads 공식 API (Meta Graph API)
# Meta Developer → 앱 → Threads API → 사용자 액세스 토큰
THREADS_ACCESS_TOKEN=your_threads_long_lived_token_here
THREADS_USER_ID=your_numeric_user_id_here   # 예: 26569579222744382

# 네이버 쇼핑 검색 API (https://developers.naver.com/apps)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Groq API (무료, https://console.groq.com)
GROQ_API_KEY=your_groq_api_key

# YouTube Data API v3 (Google Cloud Console → YouTube Data API v3)
YOUTUBE_API_KEY=your_youtube_api_key

# Claude AI (선택 — 현재 미사용, Groq로 대체)
# ANTHROPIC_API_KEY=your_anthropic_api_key
